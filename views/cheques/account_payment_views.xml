<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_form_inherited_atk_check" model="ir.ui.view">
        <field name="name">account.payment.form.inherited.bahrain.check</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_check_bh" 
                        string="Print Bahraini Check" 
                        type="object" 
                        class="btn-primary" 
                        invisible="state not in ('posted', 'in_process')"/>
            </xpath>
            <xpath expr="//field[@name='memo']" position="after">
                <field name="is_check_payment" invisible="1"/>
                <field name="check_number" invisible="not is_check_payment" readonly="state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>
