<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tally_account_mapping_list" model="ir.ui.view">
        <field name="name">tally.account.mapping.list</field>
        <field name="model">tally.account.mapping</field>
        <field name="arch" type="xml">
            <list string="Tally Mappings" editable="bottom">
                <field name="tally_ledger_name"/>
                <field name="tally_group"/>
                <field name="odoo_account_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_tally_account_mapping" model="ir.actions.act_window">
        <field name="name">Tally Account Mappings</field>
        <field name="res_model">tally.account.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_tally_group_mapping_list" model="ir.ui.view">
        <field name="name">tally.group.mapping.list</field>
        <field name="model">tally.group.mapping</field>
        <field name="arch" type="xml">
            <list string="Group Mappings" editable="bottom">
                <field name="tally_group_name"/>
                <field name="odoo_group_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_tally_group_mapping" model="ir.actions.act_window">
        <field name="name">Group Mappings</field>
        <field name="res_model">tally.group.mapping</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_tally_voucher_mapping_list" model="ir.ui.view">
        <field name="name">tally.voucher.mapping.list</field>
        <field name="model">tally.voucher.mapping</field>
        <field name="arch" type="xml">
            <list string="Voucher Mappings" editable="bottom">
                <field name="tally_voucher_type"/>
                <field name="odoo_journal_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_tally_voucher_mapping" model="ir.actions.act_window">
        <field name="name">Voucher Mappings</field>
        <field name="res_model">tally.voucher.mapping</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
