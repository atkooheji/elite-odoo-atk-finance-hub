<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tally_import_batch_form" model="ir.ui.view">
        <field name="name">tally.import.batch.form</field>
        <field name="model">tally.import.batch</field>
        <field name="arch" type="xml">
            <form string="Tally Import Batch">
                <header>
                    <button name="action_import_file" string="Start Import" type="object" class="btn-primary" invisible="state != 'draft' or not import_file"/>
                    <button name="action_undo_import" string="Undo Import" type="object" class="btn-outline-danger" invisible="state == 'canceled'" confirm="This will delete ALL journal entries from this batch. Continue?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Import Details">
                            <field name="import_file" filename="file_name" widget="binary"/>
                            <field name="file_name" invisible="1"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="import_date"/>
                        </group>
                        <group string="Stats">
                            <field name="total_count"/>
                            <field name="posted_count"/>
                            <field name="draft_count"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Vouchers" name="vouchers">
                            <field name="move_ids" readonly="1">
                                <list decoration-info="state == 'draft'" decoration-success="state == 'posted'">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="ref"/>
                                    <field name="amount_total_signed" sum="Total"/>
                                    <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'posted'"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_tally_import_batch_list" model="ir.ui.view">
        <field name="name">tally.import.batch.list</field>
        <field name="model">tally.import.batch</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'done'" decoration-warning="state == 'draft'">
                <field name="name"/>
                <field name="file_name"/>
                <field name="import_date"/>
                <field name="total_count"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_tally_import_batch" model="ir.actions.act_window">
        <field name="name">Tally Import Batches</field>
        <field name="res_model">tally.import.batch</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
