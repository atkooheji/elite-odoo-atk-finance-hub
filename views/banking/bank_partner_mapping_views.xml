<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bank_partner_mapping_list" model="ir.ui.view">
        <field name="name">bank.partner.mapping.list</field>
        <field name="model">bank.partner.mapping</field>
        <field name="arch" type="xml">
            <list string="Bank Partner Mappings" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="action_bank_partner_mapping" model="ir.actions.act_window">
        <field name="name">Bank Partner Mappings</field>
        <field name="res_model">bank.partner.mapping</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create keyword mappings for automatic partner detection.
            </p>
            <p>
                Example: Keyword "VIVA" maps to Partner "STC Bahrain".
            </p>
        </field>
    </record>
</odoo>
