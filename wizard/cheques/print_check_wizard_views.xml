<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_print_check_bh_wizard_form" model="ir.ui.view">
        <field name="name">print.check.bh.wizard.form</field>
        <field name="model">print.check.bh.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Bahraini Check">
                <group>
                    <field name="payment_id" invisible="1"/>
                    <field name="journal_id" readonly="1"/>
                    <field name="check_number"/>
                </group>
                <footer>
                    <button name="action_print" string="Print Check" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_print_check_bh_wizard" model="ir.actions.act_window">
        <field name="name">Print Bahraini Check</field>
        <field name="res_model">print.check.bh.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
